[Unit]
Description=ControlToKey - JoyToKey Accessibility Daemon for Linux
After=multi-user.target
Wants=udev.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/controltokey
ExecStart=/usr/bin/python3 /opt/controltokey/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
